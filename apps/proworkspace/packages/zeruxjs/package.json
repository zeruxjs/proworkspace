{
  "name": "zeruxjs",
  "version": "0.0.1-alpha.1",
  "description": "Main application ZeruxJS Framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "zerux": "./dist/bin/zerux.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "exports": {
    ".": "./dist/index.js",
    "./navigation": "./dist/navigation.js",
    "./cache": "./dist/cache-api.js",
    "./loader": "./dist/loader/register-loader.js",
    "./database": "./dist/bootstrap/database.js",
    "./cache-runtime": "./dist/bootstrap/cache.js",
    "./schema/schema.config.json": "./assets/json/schema.config.json",
    "./theme": "./dist/theme.js"
  },
  "license": "(MIT OR Apache-2.0)",
  "dependencies": {
    "@zeruxjs/cache": "*",
    "@zeruxjs/db": "*",
    "z-dev": "*",
    "@zeruxjs/hooks": "*",
    "zsrv": "*",
    "zcli": "*"
  },
  "homepage": "https://github.com/zeruxjs/zeruxjs#readme",
  "bugs": {
    "url": "https://github.com/zeruxjs/zeruxjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeruxjs/zeruxjs.git"
  },
  "keywords": [
    "Main application ZeruxJS Framework"
  ]
